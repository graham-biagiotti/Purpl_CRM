rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Portal: public can read accounts for token lookup
    match /accounts/{accountId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Portal: public can read prospects for token lookup
    match /prospects/{prospectId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Portal: public can read and submit orders
    match /portal_orders/{orderId} {
      allow read, create: if true;
      allow update, delete: if request.auth != null;
    }

    // Portal: public can sign up for notifications
    match /portal_notify/{docId} {
      allow create: if true;
      allow read, delete: if request.auth != null;
    }

    // Portal: public can read settings for mode
    match /portal_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Wholesale page: public can submit inquiries
    match /portal_inquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    // Everything else requires auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
