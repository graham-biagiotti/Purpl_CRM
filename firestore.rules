rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Default: authenticated CRM users only ──────────
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // ── Portal token lookup ────────────────────────────
    // Unauthenticated read allowed (returns only accountName + email).
    // Write only by authenticated CRM users (when generating links).
    match /portal_tokens/{token} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Portal configuration (mode, price, deadline) ───
    // Unauthenticated read for the public order form.
    // Write only by authenticated CRM users.
    match /portal_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Accounts (portal token lookup) ─────────────────
    // Unauthenticated read allowed for token-based lookups.
    // Write only by authenticated CRM users.
    match /accounts/{id} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // ── Portal order submissions ───────────────────────
    // Unauthenticated write: public form can submit orders.
    // Read only by authenticated CRM users.
    match /portal_orders/{id} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // ── Coming Soon notification signups ───────────────
    // Unauthenticated write: public form can sign up.
    // Read only by authenticated CRM users.
    match /portal_notify/{notifyId} {
      allow read: if request.auth != null;
      allow write: if true;
    }
  }
}
