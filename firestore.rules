rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Authenticated users can read/write everything
    match /{document=**} {
      allow read, write: if request.auth != null;
    }

    // Portal: accounts readable by anyone for token lookup
    match /accounts/{accountId} {
      allow read: if true;
    }

    // Portal: prospects readable by anyone for token lookup
    match /prospects/{prospectId} {
      allow read: if true;
    }

    // Portal: anyone can submit an order
    match /portal_orders/{orderId} {
      allow create: if true;
      allow read, update: if request.auth != null;
    }

    // Portal: notify me signups
    match /portal_notify/{docId} {
      allow create: if true;
      allow read: if request.auth != null;
    }

    // Portal: read settings to know mode
    match /portal_settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
