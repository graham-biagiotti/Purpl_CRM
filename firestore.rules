rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if the authenticated user has admin role
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Users collection: user can read own doc, admins can read/write all
    match /users/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create: if request.auth != null && request.auth.uid == userId;
      allow update, delete: if isAdmin();
    }

    // Accounts and prospects: auth required for all access.
    match /accounts/{accountId} {
      allow read, write: if request.auth != null;
    }

    match /prospects/{prospectId} {
      allow read, write: if request.auth != null;
    }

    // Portal: public can submit orders (create only)
    match /portal_orders/{orderId} {
      allow create: if true
        && request.resource.data.keys().hasAll(['accountName', 'billingEmail', 'status'])
        && request.resource.data.accountName is string
        && request.resource.data.accountName.size() < 200
        && request.resource.data.billingEmail is string
        && request.resource.data.billingEmail.size() < 200
        && request.resource.data.status in ['new', 'pending']
        && (!('notes' in request.resource.data) || (request.resource.data.notes is string && request.resource.data.notes.size() < 2000))
        && (!('items' in request.resource.data) || request.resource.data.items.size() < 50)
        && (!('lineItems' in request.resource.data) || request.resource.data.lineItems.size() < 50)
        && request.resource.data.size() < 50;
      allow read: if true;
      allow update, delete: if request.auth != null;
    }

    // Portal: public can sign up for notifications
    match /portal_notify/{docId} {
      allow create: if true
        && request.resource.data.keys().hasAll(['email', 'flavor'])
        && request.resource.data.email is string
        && request.resource.data.email.size() < 200
        && request.resource.data.flavor is string
        && request.resource.data.flavor.size() < 100
        && request.resource.data.size() < 10;
      allow read, delete: if request.auth != null;
    }

    // Portal settings: admin-only (Cloud Functions serve public fields)
    match /portal_settings/{docId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Wholesale page: public can submit inquiries
    match /portal_inquiries/{docId} {
      allow create: if true
        && request.resource.data.keys().hasAll(['businessName', 'email'])
        && request.resource.data.businessName is string
        && request.resource.data.businessName.size() < 200
        && request.resource.data.email is string
        && request.resource.data.email.size() < 200
        && (!('message' in request.resource.data) || (request.resource.data.message is string && request.resource.data.message.size() < 5000))
        && request.resource.data.size() < 20;
      allow read, update, delete: if request.auth != null;
    }

    // Workspace data: all auth users can read/write (employees need full access)
    // Sensitive config writes restricted to admin
    match /workspace/{path=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // Everything else requires auth
    match /{document=**} {
      allow read, write: if request.auth != null;
    }
  }
}
